{
  "name": "discord-bot-peer-bonus",
  "version": "0.1.0",
  "description": "The Peer Bonus Discord Bot implemented by the Knowledge Base Executive Committee.",
  "license": "MIT",
  "author": "minagishl",
  "type": "commonjs",
  "scripts": {
    "build": "bun run rm && tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "esbuild": "bun run rm && node scripts/build.js",
    "check": "bun run lint && bun run format:check",
    "check:write": "bun run lint:fix && bun run format",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint ./src",
    "lint:fix": "oxlint --fix ./src",
    "register": "tsx src/register.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "rm": "node scripts/rm.js"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "better-sqlite3": "^12.9.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "esbuild": "^0.28.0",
    "lint-staged": "^17.0.2",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "bun run lint:fix",
      "bun run format"
    ]
  }
}
